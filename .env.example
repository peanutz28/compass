# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Squads multisig (populated by provision script — do not edit manually)
MULTISIG_PDA=
VAULT_PDA=
AGENT_MEMBER_PUBKEY=
CAREGIVER_MEMBER_PUBKEY=

# Agent keypair (the "hot" key the agent uses to propose transactions)
AGENT_KEYPAIR_PATH=./keys/agent.json

# Policy server
POLICY_SERVER_URL=http://localhost:3001
POLICY_SERVER_SECRET=compass-demo-secret-2026
PORT=3001

# Dashboard
NEXT_PUBLIC_POLICY_SERVER_URL=http://localhost:3001

# Database
DB_PATH=./apps/policy-server/compass.db

# Notifications (use ethereal.email for demo — fake SMTP, no real email needed)
# Get free credentials at: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CAREGIVER_EMAIL=sarah@example.com

# Key storage
KEYCHAIN_SERVICE=compass-app
KEYCHAIN_ACCOUNT=caregiver-key
EMAIL_RECOVERY_FILE_PATH=./keys/email-recovery-encrypted.json
EMAIL_RECOVERY_PASSPHRASE=demo-passphrase-change-me
